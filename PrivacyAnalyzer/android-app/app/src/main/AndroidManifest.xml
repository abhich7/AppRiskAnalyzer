<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cyberprotect.privacyanalyzer">

    <!-- Crucial permission to scan all installed apps across SDK levels 30 to 35 -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Legacy compatibility flag for PDF document writing on Android 10 and below -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <application
        android:name=".PrivacyAnalyzerApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Privacy Analyzer Pro"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrivacyAnalyzer">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PrivacyAnalyzer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>